generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String          @default("Prince@Gaur@786")
  role           String          @default("SALESPERSON")
  orders         Order[]
  stageTrackings StageTracking[]
}

model Order {
  id                       String          @id @default(uuid())
  salespersonId            String
  salesperson              User            @relation(fields: [salespersonId], references: [id])
  clientName               String
  mobileNumber             String
  emailId                  String
  systemSizeKw             Float
  quotationAmount          Float
  currentStage             String          @default("ORDER")
  loanStage                String?         @default("PRE_SALES")
  loanSubStage             String?         @default("Waiting for customer response")
  paymentType              String?         @default("FULL_PAYMENT") // FULL_PAYMENT, BAJAJ_FINANCE, BANK_LOAN
  loanType                 String?
  paymentAmountCollected   Float           @default(0) // Deposit
  totalPaidAmount          Float           @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  lastStageUpdatedAt       DateTime        @default(now())

  payments                 Payment[]
  shipment                 Shipment?
  documents                Document[]
  stageTrackings           StageTracking[]
  installations            Installation[]
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Float
  paymentMode     String   // CASH, UPI, BANK_TRANSFER
  referenceNumber String
  paymentDate     DateTime @default(now())
  proofUrl        String?
  createdAt       DateTime @default(now())
}

model Shipment {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  productDetails  String?
  vehicleNumber   String?
  driverName      String?
  sentDate        DateTime @default(now())
  dispatchProofUrl String?
  createdAt       DateTime @default(now())
}

model Document {
  id           String       @id @default(uuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  documentType String
  fileUrl      String
  stage        String?      // Which stage this doc belongs to
  uploadedAt   DateTime     @default(now())
}

model StageTracking {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  stage       String
  subStage    String?
  updatedById String
  updatedBy   User     @relation(fields: [updatedById], references: [id])
  updatedAt   DateTime @default(now())
}

model Installation {
  id               String    @id @default(uuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id])
  installationDate DateTime?
  teamAssigned     String?
}
